{
  "name": "dorothy",
  "version": "1.2.7",
  "private": true,
  "main": "electron/dist/main.js",
  "scripts": {
    "dev": "next dev",
    "dev:network": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "postinstall": "node node_modules/electron/install.js",
    "electron:dev": "concurrently \"npm run dev\" \"npm run electron:start\"",
    "electron:start": "wait-on http://localhost:3000 && tsc -p electron/tsconfig.json && cross-env NODE_ENV=development electron .",
    "electron:build:win": "node scripts/build-electron.mjs win",
    "electron:build:mac": "node scripts/build-electron.mjs mac",
    "electron:build:linux": "node scripts/build-electron.mjs linux",
    "electron:pack:win": "node scripts/build-electron.mjs win --pack",
    "electron:build": "node scripts/build-electron.mjs mac",
    "electron:pack": "node scripts/build-electron.mjs mac --pack",
    "generate:ico": "node scripts/generate-ico.mjs"
  },
  "build": {
    "appId": "io.dorothy.app",
    "productName": "Dorothy",
    "npmRebuild": false,
    "publish": {
      "provider": "github",
      "owner": "Nexarion434",
      "repo": "Dorothy"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/dist/**/*",
      "electron/resources/**/*",
      "out/**/*",
      "node_modules/**/*",
      "!node_modules/@next/swc*",
      "!node_modules/@next/env",
      "!node_modules/@next/eslint-plugin-next",
      "skills/**/*",
      "hooks/**/*"
    ],
    "asarUnpack": [
      "out/**/*",
      "hooks/**/*",
      "electron/resources/**/*",
      "node_modules/better-sqlite3/**/*",
      "node_modules/node-pty/**/*"
    ],
    "extraResources": [
      {
        "from": "mcp-orchestrator",
        "to": "mcp-orchestrator",
        "filter": [
          "package.json",
          "dist/bundle.js"
        ]
      },
      {
        "from": "mcp-telegram",
        "to": "mcp-telegram",
        "filter": [
          "package.json",
          "dist/bundle.js"
        ]
      },
      {
        "from": "mcp-kanban",
        "to": "mcp-kanban",
        "filter": [
          "package.json",
          "dist/bundle.js"
        ]
      },
      {
        "from": "mcp-vault",
        "to": "mcp-vault",
        "filter": [
          "package.json",
          "dist/bundle.js"
        ]
      },
      {
        "from": "mcp-socialdata",
        "to": "mcp-socialdata",
        "filter": [
          "package.json",
          "dist/bundle.js"
        ]
      },
      {
        "from": "mcp-x",
        "to": "mcp-x",
        "filter": [
          "package.json",
          "dist/bundle.js"
        ]
      },
      {
        "from": "mcp-world",
        "to": "mcp-world",
        "filter": [
          "package.json",
          "dist/bundle.js"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.ico",
      "publisherName": "Nicolas / The Black Sea",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Dorothy",
      "include": "build/installer.nsh",
      "artifactName": "Dorothy-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "Dorothy-${version}-portable-${arch}.${ext}"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "public/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "title": "Dorothy",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@slack/bolt": "^4.0.1",
    "better-sqlite3": "^11.0.0",
    "call-bind": "^1.0.8",
    "call-bind-apply-helpers": "^1.0.2",
    "dunder-proto": "^1.0.1",
    "electron-updater": "^6.3.9",
    "framer-motion": "^12.29.0",
    "get-intrinsic": "^1.3.0",
    "get-proto": "^1.0.1",
    "lucide-react": "^0.563.0",
    "next": "^16.1.4",
    "node-pty": "^1.1.0",
    "node-telegram-bot-api": "^0.67.0",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-grid-layout": "^2.2.2",
    "set-function-length": "^1.2.2",
    "three": "^0.182.0",
    "uuid": "^9.0.1",
    "which": "^6.0.1",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.2",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/node-telegram-bot-api": "^0.64.13",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^9.0.8",
    "@types/which": "^3.0.4",
    "concurrently": "^9.1.0",
    "cross-env": "^10.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.4",
    "node-cron": "^4.2.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.18",
    "wait-on": "^8.0.1"
  }
}
